#!/usr/bin/env bash
set -euo pipefail

if ! command -v sudo > /dev/null 2>&1; then
  echo "uninstall-faradai: sudo is required but not available" >&2
  exit 1
fi

# If any faradai containers are currently running, ask before force-removing them.
_running=$(docker ps --filter "label=dev.faradai.managed=true" --format "{{.Names}}" 2>/dev/null || true)
if [[ -n "${_running}" ]]; then
  echo "The following faradai containers are currently running:"
  echo "${_running}"
  read -r -p "Kill them and proceed with uninstall? [y/N] " _confirm_containers

  case "${_confirm_containers}" in
    [yY])
      while IFS= read -r _cid; do
        docker rm -f "${_cid}"
      done < <(docker ps -q --filter "label=dev.faradai.managed=true" 2>/dev/null)
      ;;
    *) echo "Aborted."; exit 0 ;;
  esac
fi

# Build a list of everything that will be removed.
_items=()

# Stopped containers matching faradai or faradai-*
_stopped=$(docker ps -aq --filter "label=dev.faradai.managed=true" 2>/dev/null || true)
if [[ -n "${_stopped}" ]]; then
  while IFS= read -r _cid; do
    _cname=$(docker inspect --format "{{.Name}}" "${_cid}" | sed 's|^/||')
    _items+=("  container: ${_cname} (stopped)")
  done <<< "${_stopped}"
fi

if docker image inspect faradai:latest 2>/dev/null >/dev/null; then
  _items+=("  image:     faradai:latest")
fi

if [ -f /usr/local/bin/faradai ]; then
  _items+=("  binary:    /usr/local/bin/faradai")
fi

if [ -f /usr/local/bin/uninstall-faradai ]; then
  _items+=("  binary:    /usr/local/bin/uninstall-faradai")
fi

if [ "${#_items[@]}" -eq 0 ]; then
  echo "Nothing to remove."
  exit 0
fi

echo "The following will be removed:"
printf '%s\n' "${_items[@]}"
read -r -p "Proceed? [y/N] " _confirm_removal

case "${_confirm_removal}" in
  [yY]) ;;
  *) echo "Aborted."; exit 0 ;;
esac

# Remove all faradai containers, the image, and the installed binaries.
while IFS= read -r _cid; do
  docker rm -f "${_cid}" 2>/dev/null || true
done < <(docker ps -aq --filter "label=dev.faradai.managed=true" 2>/dev/null || true)

docker rmi faradai:latest 2>/dev/null || true
sudo rm -f /usr/local/bin/faradai
sudo rm -f /usr/local/bin/uninstall-faradai
echo "Done."
echo ""
echo "The following are not removed and must be deleted manually if desired:"
echo "  ~/.claude/        Claude Code settings, memory, and conversation history"
echo "  ~/.claude.json    Claude Code top-level config"
echo "  ~/.config/gh/     GitHub CLI auth tokens"
echo "  faradai source directory (wherever you cloned it)"
