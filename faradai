#!/usr/bin/env bash
set -euo pipefail

_FARADAI_VERSION="0.1.0"

# ── functions ──────────────────────────────────────────────────────────────────

_usage() {
  cat <<'EOF'
Usage: faradai [-n NAME | -a [NAME]] [COMMAND [ARGS...]]

Flags:
  -n NAME   Create container faradai-NAME; error if it already exists
  -a [NAME] Attach to running faradai-NAME (or default faradai); error if not running
  (none)    Auto-detect: attach if default faradai is running, create if not

Commands:
  (none)     Launch Claude Code (default)
  claude     Launch Claude Code; remaining args passed through (e.g. --resume)
  aider      Launch aider; remaining args passed through (e.g. --no-git)
  bash       Open a bash shell inside the container
  logs       Stream container logs; remaining args passed to docker logs (e.g. -f)
  status     Show container state, image, and start time
  version    Print the faradai CLI version
  update     Pull the latest release and reinstall
  uninstall  Remove the faradai container(s), image, and installed binaries
  help       Show this help message

Environment variables:
  FARADAI_WORKDIR           Project directory (default: current directory)
  FARADAI_TRUST_DIR         Set to 1 to skip the directory trust prompt
  FARADAI_MEMORY            Container RAM limit (default: 4g)
  FARADAI_CPUS              Container CPU limit (default: 4)
  FARADAI_PIDS              Container PID limit (default: 512)
  FARADAI_NETWORK_MODE      Network access: open (default) or none (no outbound network)
  FARADAI_ENABLE_SSH_AGENT  Forward SSH agent socket when available (default: 1)
  FARADAI_TRUST_SSH_AGENT   Set to 1 to skip the SSH agent forwarding confirmation prompt (default: 0)
  FARADAI_MOUNT_SSH_DIR     Mount ~/.ssh read-only into the container (default: 0)
  FARADAI_DOCKER_ARGS       Extra flags appended to docker run (always: --env/-e, --label/-l, --hostname; opt-in: --device, --publish/-p)
  FARADAI_ALLOW_DEVICE      Set to 1 to permit --device in FARADAI_DOCKER_ARGS (opens host hardware to container)
  FARADAI_ALLOW_PUBLISH     Set to 1 to permit --publish/-p in FARADAI_DOCKER_ARGS (exposes container ports to host)
  FARADAI_DEBUG             Set to 1 to print resolved config and docker command before running
EOF
}

_cleanup() { docker rm -f "${_CONTAINER_NAME}" 2>/dev/null || true; }

_validate_memory() {
  # k (kilobytes) intentionally omitted — not a realistic container memory unit
  [[ "${FARADAI_MEMORY}" =~ ^([0-9]+(\.[0-9]+)?)([mgMG])$ ]] || {
    echo "faradai: invalid FARADAI_MEMORY '${FARADAI_MEMORY}' (expected e.g. 4g or 512m)" >&2
    exit 1
  }
  local num="${BASH_REMATCH[1]}" unit="${BASH_REMATCH[3],,}" int="${BASH_REMATCH[1]%%.*}"
  # Reject zero: 0 and 0.0 are invalid, but 0.5 is fine — check integer part is 0
  # and either there's no decimal or the decimal part is all zeros.
  if (( int == 0 )) && { [[ "${num}" != *.* ]] || [[ "${num#*.}" =~ ^0+$ ]]; }; then
    echo "faradai: FARADAI_MEMORY must be greater than zero" >&2
    exit 1
  fi
  if { [[ "${unit}" == "g" ]] && (( int > 512 )); } ||
     { [[ "${unit}" == "m" ]] && (( int > 524288 )); }; then
    echo "faradai: FARADAI_MEMORY '${FARADAI_MEMORY}' exceeds the 512g sanity limit" >&2
    exit 1
  fi
}

_validate_cpus() {
  # %.* strips the decimal so (( )) can do an integer bound check (bash can't compare floats natively).
  [[ "${FARADAI_CPUS}" =~ ^[0-9]+(\.[0-9]+)?$ ]] && (( ${FARADAI_CPUS%.*} <= 128 )) || {
    echo "faradai: invalid FARADAI_CPUS '${FARADAI_CPUS}' (expected a number <= 128, e.g. 4 or 2.5)" >&2
    exit 1
  }
  awk -v v="${FARADAI_CPUS}" 'BEGIN { if (v <= 0) { print "faradai: FARADAI_CPUS must be greater than zero" > "/dev/stderr"; exit 1 } }' || exit 1
}

_validate_pids() {
  [[ "${FARADAI_PIDS}" =~ ^[0-9]+$ ]] || {
    echo "faradai: invalid FARADAI_PIDS '${FARADAI_PIDS}' (expected a positive integer)" >&2
    exit 1
  }
  if (( FARADAI_PIDS < 1 )); then
    echo "faradai: FARADAI_PIDS must be at least 1" >&2
    exit 1
  fi
}

_validate_network_mode() {
  [[ "${FARADAI_NETWORK_MODE}" == "open" || "${FARADAI_NETWORK_MODE}" == "none" ]] || {
    echo "faradai: invalid FARADAI_NETWORK_MODE '${FARADAI_NETWORK_MODE}' (expected: open, none)" >&2
    exit 1
  }
}

_build_extra_docker_args() {
  [[ -z "${FARADAI_DOCKER_ARGS:-}" ]] && return
  # Word-split only — paths with spaces are not supported.
  read -ra EXTRA_DOCKER_ARGS <<< "${FARADAI_DOCKER_ARGS}"
  local permitted=(--env -e --label -l --hostname)
  [[ "${FARADAI_ALLOW_DEVICE:-0}"  == "1" ]] && permitted+=(--device)
  [[ "${FARADAI_ALLOW_PUBLISH:-0}" == "1" ]] && permitted+=(--publish -p)
  local arg flag ok
  for arg in "${EXTRA_DOCKER_ARGS[@]}"; do
    [[ "${arg}" != -* ]] && continue
    ok=0
    for flag in "${permitted[@]}"; do
      [[ "${arg}" == "${flag}" || "${arg}" == "${flag}="* ]] && { ok=1; break; }
    done
    (( ok )) || {
      echo "faradai: FARADAI_DOCKER_ARGS flag '${arg}' is not permitted" >&2
      echo "faradai: always permitted: --env/-e, --label/-l, --hostname" >&2
      echo "faradai: opt-in: --device (FARADAI_ALLOW_DEVICE=1), --publish/-p (FARADAI_ALLOW_PUBLISH=1)" >&2
      exit 1
    }
  done
}

# ── flag parsing ───────────────────────────────────────────────────────────────

# Manual loop avoids getopts consuming --help before subcommand dispatch sees it.
# -n and -a are mutually exclusive; -a optionally takes a NAME argument.
# Known tool commands are not consumed as NAME after -a.
_KNOWN_CMDS=(claude aider bash logs status version --version update uninstall help --help -h)
_CONTAINER_NAME="faradai"
_MODE="auto"   # auto | create | attach

_args=("$@")
_remaining=()
_i=0
while (( _i < ${#_args[@]} )); do
  case "${_args[_i]}" in
    -n)
      [[ "${_MODE}" == "attach" ]] && { echo "faradai: -n and -a are mutually exclusive" >&2; exit 1; }
      _i=$(( _i + 1 ))
      if (( _i >= ${#_args[@]} )) || [[ "${_args[_i]}" == -* ]]; then
        echo "faradai: -n requires a NAME argument (e.g. faradai -n myproject)" >&2; exit 1
      fi
      _CONTAINER_NAME="faradai-${_args[_i]}"
      _MODE="create"
      ;;
    -a)
      [[ "${_MODE}" == "create" ]] && { echo "faradai: -n and -a are mutually exclusive" >&2; exit 1; }
      _MODE="attach"
      # Consume the next arg as NAME only if it is not a known command or flag.
      _next="${_args[$(( _i + 1 ))]:-}"
      _is_cmd=false
      for _cmd in "${_KNOWN_CMDS[@]}"; do
        [[ "${_next}" == "${_cmd}" ]] && { _is_cmd=true; break; }
      done

      if [[ -n "${_next}" && "${_next}" != -* && "${_is_cmd}" == "false" ]]; then
        _CONTAINER_NAME="faradai-${_next}"
        _i=$(( _i + 1 ))
      fi
      ;;
    *)
      _remaining+=("${_args[_i]}")
      ;;
  esac
  _i=$(( _i + 1 ))
done

# ${array[@]+expansion} guards against set -u errors on empty arrays.
set -- "${_remaining[@]+"${_remaining[@]}"}"

# ── subcommand dispatch ────────────────────────────────────────────────────────

case "${1:-}" in
  --help|-h|help)
    _usage
    exit 0
    ;;
  version|--version)
    echo "faradai ${_FARADAI_VERSION}"
    exit 0
    ;;
  update)
    _update_dir="$(mktemp -d /tmp/faradai-update-XXXXXX)"
    trap 'rm -rf "${_update_dir}"' EXIT
    git clone https://github.com/josiah14-automation-engineering/faradai.git "${_update_dir}" \
      || { echo "faradai: git clone failed — check your network connection and try again" >&2; exit 1; }
    "${_update_dir}/install.sh"
    exit 0
    ;;
  uninstall)
    exec /usr/local/bin/uninstall-faradai
    ;;
esac

# ── docker pre-flight ──────────────────────────────────────────────────────────

command -v docker > /dev/null 2>&1 || { echo "faradai: docker is not installed or not in PATH" >&2; exit 1; }
docker info > /dev/null 2>&1 || { echo "faradai: Docker daemon is not running" >&2; exit 1; }

case "${1:-}" in
  logs)
    exec docker logs "${_CONTAINER_NAME}" "${@:2}"
    ;;
  status)
    docker inspect "${_CONTAINER_NAME}" \
      --format 'name:    {{slice .Name 1}}
state:   {{.State.Status}}
started: {{.State.StartedAt}}
image:   {{.Config.Image}}' 2>/dev/null \
      || { echo "faradai: container '${_CONTAINER_NAME}' not found" >&2; exit 1; }
    exit 0
    ;;
esac

docker image inspect faradai:latest > /dev/null 2>&1 || { echo "faradai: image not found — run './install.sh' to build it" >&2; exit 1; }

# ── resolve workdir ────────────────────────────────────────────────────────────

FARADAI_WORKDIR="${FARADAI_WORKDIR:-$(pwd)}"
[ -d "${FARADAI_WORKDIR}" ] || { echo "faradai: FARADAI_WORKDIR does not exist: ${FARADAI_WORKDIR}" >&2; exit 1; }

# ── attach if already running ─────────────────────────────────────────────────

# docker inspect exits non-zero if the container doesn't exist; || clears the var rather than aborting.
_is_running="$(docker inspect --format '{{.State.Running}}' "${_CONTAINER_NAME}" 2>/dev/null)" || _is_running=""

if [[ "${_MODE}" == "attach" ]]; then
  if [[ "${_is_running}" != "true" ]]; then
    if [[ "${_CONTAINER_NAME}" == "faradai" ]]; then
      echo "faradai: no running container '${_CONTAINER_NAME}' — start one with: faradai" >&2
    else
      echo "faradai: no running container '${_CONTAINER_NAME}' — start one with: faradai -n ${_CONTAINER_NAME#faradai-}" >&2
    fi
    exit 1
  fi
  exec docker exec -it "${_CONTAINER_NAME}" "${@:-claude}"
fi

if [[ "${_MODE}" == "auto" && "${_is_running}" == "true" ]]; then
  exec docker exec -it "${_CONTAINER_NAME}" "${@:-claude}"
fi

# ── trust prompt ──────────────────────────────────────────────────────────────

if [[ "${FARADAI_TRUST_DIR:-0}" != "1" ]]; then
  printf "faradai: mount %s into container? [y/N] " "${FARADAI_WORKDIR}"
  read -r _trust_answer
  [[ "${_trust_answer}" =~ ^[Yy]$ ]] || { echo "faradai: aborted." >&2; exit 0; }
fi

# ── create mode: error if container already exists ────────────────────────────

if [[ "${_MODE}" == "create" ]] && docker inspect "${_CONTAINER_NAME}" > /dev/null 2>&1; then
  echo "faradai: container '${_CONTAINER_NAME}' already exists — attach with: faradai -a ${_CONTAINER_NAME#faradai-}" >&2
  exit 1
fi

# ── start fresh: cleanup + trap ───────────────────────────────────────────────

# Remove any stopped container so --name doesn't conflict.
docker rm -f "${_CONTAINER_NAME}" 2>/dev/null || true
# Trap fires only in the narrow window before exec docker run replaces this process.
trap _cleanup INT TERM EXIT

# ── config defaults + validation ──────────────────────────────────────────────

FARADAI_MEMORY="${FARADAI_MEMORY:-4g}"
FARADAI_CPUS="${FARADAI_CPUS:-4}"
FARADAI_PIDS="${FARADAI_PIDS:-512}"
FARADAI_NETWORK_MODE="${FARADAI_NETWORK_MODE:-open}"

_validate_memory
_validate_cpus
_validate_pids
_validate_network_mode

NETWORK_ARGS=()
[[ "${FARADAI_NETWORK_MODE}" == "none" ]] && NETWORK_ARGS=(--network none)

# ── build optional mount arrays ───────────────────────────────────────────────

USER="$(whoami)"

mkdir -p "${HOME}/.config/gh"
GH_CONFIG_ARGS=(-v "${HOME}/.config/gh:/home/${USER}/.config/gh")

AIDER_CONF_MOUNT=()
[[ -f "${HOME}/.aider.conf.yml" ]] && AIDER_CONF_MOUNT=(-v "${HOME}/.aider.conf.yml:/home/${USER}/.aider.conf.yml:ro")

SSH_AGENT_ARGS=()
if [[ "${FARADAI_ENABLE_SSH_AGENT:-1}" == "1" && -n "${SSH_AUTH_SOCK:-}" && -S "${SSH_AUTH_SOCK}" ]]; then
  _forward_agent=1

  if [[ "${FARADAI_TRUST_SSH_AGENT:-0}" != "1" ]]; then
    echo "faradai: SSH agent socket detected. Keys that will be accessible inside the container if forwarded:" >&2
    ssh-add -l 2>/dev/null || echo "  (no keys loaded)" >&2
    printf "faradai: forward SSH agent into container? [y/N] "
    read -r _ssh_agent_answer
    [[ "${_ssh_agent_answer}" =~ ^[Yy]$ ]] || _forward_agent=0
  fi

  (( _forward_agent )) && SSH_AGENT_ARGS=(-v "${SSH_AUTH_SOCK}:/ssh-agent" -e SSH_AUTH_SOCK=/ssh-agent)
fi

SSH_DIR_ARGS=()
[[ "${FARADAI_MOUNT_SSH_DIR:-0}" == "1" ]] && SSH_DIR_ARGS=(-v "${HOME}/.ssh:/home/${USER}/.ssh:ro")

EXTRA_DOCKER_ARGS=()
_build_extra_docker_args

# ── debug ─────────────────────────────────────────────────────────────────────

if [[ "${FARADAI_DEBUG:-0}" == "1" ]]; then
  echo "faradai: CONTAINER=${_CONTAINER_NAME} WORKDIR=${FARADAI_WORKDIR} MEMORY=${FARADAI_MEMORY} CPUS=${FARADAI_CPUS} PIDS=${FARADAI_PIDS} NETWORK=${FARADAI_NETWORK_MODE}" >&2
  set -x
fi

# ── run ───────────────────────────────────────────────────────────────────────

exec docker run -it --rm \
  --init \
  --name "${_CONTAINER_NAME}" \
  --memory="${FARADAI_MEMORY}" \
  --cpus="${FARADAI_CPUS}" \
  --pids-limit="${FARADAI_PIDS}" \
  --cap-drop ALL \
  --security-opt no-new-privileges:true \
  "${NETWORK_ARGS[@]}" \
  -v "${HOME}/.claude:/home/${USER}/.claude" \
  -v "${HOME}/.claude/.credentials.json:/home/${USER}/.claude/.credentials.json:ro" \
  -v "${HOME}/.claude.json:/home/${USER}/.claude.json" \
  -v "${HOME}/.gitconfig:/home/${USER}/.gitconfig:ro" \
  "${GH_CONFIG_ARGS[@]}" \
  "${SSH_AGENT_ARGS[@]}" \
  "${SSH_DIR_ARGS[@]}" \
  -v "${FARADAI_WORKDIR}:${FARADAI_WORKDIR}" \
  "${AIDER_CONF_MOUNT[@]}" \
  "${EXTRA_DOCKER_ARGS[@]}" \
  -w "${FARADAI_WORKDIR}" \
  faradai:latest \
  "$@"
