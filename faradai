#!/usr/bin/env bash
set -euo pipefail

case "${1:-}" in
  --help|-h|help)
    cat <<'EOF'
Usage: faradai [COMMAND]

Commands:
  (none)     Launch Claude Code (default)
  claude     Launch Claude Code
  aider      Launch aider
  bash       Open a bash shell inside the container
  update     Pull the latest release and reinstall
  uninstall  Remove the faradai container, image, and installed binaries
  help       Show this help message

Environment variables:
  FARADAI_WORKDIR      Project directory (default: ~/Development/personal)
  FARADAI_MEMORY       Container RAM limit (default: 4g)
  FARADAI_CPUS         Container CPU limit (default: 4)
  FARADAI_PIDS         Container PID limit (default: 512)
  FARADAI_DOCKER_ARGS  Extra flags appended to docker run (allowlist: --env/-e, --label/-l, --device, --publish/-p, --hostname)
  FARADAI_DEBUG        Set to 1 to print resolved config and docker command before running
EOF
    exit 0
    ;;
  update)
    _update_dir="$(mktemp -d /tmp/faradai-update-XXXXXX)"
    trap 'rm -rf "${_update_dir}"' EXIT
    git clone git@github.com:josiah14-automation-engineering/faradai.git "${_update_dir}"
    "${_update_dir}/install.sh"
    ;;
  uninstall)
    exec /usr/local/bin/uninstall-faradai
    ;;
esac

if docker inspect --format '{{.State.Running}}' faradai 2>/dev/null | grep -q true; then
  # exec replaces this process on success; set -e exits on failure — no exit needed
  exec docker exec -it faradai "${@:-claude}"
fi

# Remove any stopped container with this name so --name faradai doesn't conflict
docker rm -f faradai 2>/dev/null || true
# exec replaces this process on success, so this trap only fires if the script is
# interrupted or errors out before docker run fully starts.
trap 'docker rm -f faradai 2>/dev/null || true' INT TERM EXIT

FARADAI_WORKDIR="${FARADAI_WORKDIR:-${HOME}/Development/personal}"
FARADAI_MEMORY="${FARADAI_MEMORY:-4g}"
FARADAI_CPUS="${FARADAI_CPUS:-4}"
FARADAI_PIDS="${FARADAI_PIDS:-512}"

# k (kilobytes) intentionally omitted — container memory in kilobytes is not a realistic
# use case, and the equivalent ceiling (536870912k) is unreadable.
if ! [[ "${FARADAI_MEMORY}" =~ ^([0-9]+(\.[0-9]+)?)([mgMG])$ ]]; then
  echo "faradai: invalid FARADAI_MEMORY '${FARADAI_MEMORY}' (expected e.g. 4g or 512m)" >&2
  exit 1
fi
_mem_num="${BASH_REMATCH[1]}"
_mem_unit="${BASH_REMATCH[3]}"
_mem_unit="${_mem_unit,,}"
_mem_int="${_mem_num%%.*}"  # integer part for zero check and bounds comparison
if (( _mem_int == 0 )); then
  if [[ "${_mem_num}" != *.* ]] || [[ "${_mem_num#*.}" =~ ^0+$ ]]; then
    echo "faradai: FARADAI_MEMORY must be greater than zero" >&2
    exit 1
  fi
fi
if ( [[ "${_mem_unit}" == "g" ]] && (( _mem_int > 512 )) ) || \
   ( [[ "${_mem_unit}" == "m" ]] && (( _mem_int > 524288 )) ); then
  echo "faradai: FARADAI_MEMORY '${FARADAI_MEMORY}' exceeds the 512g sanity limit" >&2
  exit 1
fi

# %.*  strips the decimal so bash (( )) can do an integer comparison on the CPU count.
if ! [[ "${FARADAI_CPUS}" =~ ^[0-9]+(\.[0-9]+)?$ ]] || (( ${FARADAI_CPUS%.*} > 128 )); then
  echo "faradai: invalid FARADAI_CPUS '${FARADAI_CPUS}' (expected a number <= 128, e.g. 4 or 2.5)" >&2
  exit 1
fi

if ! [[ "${FARADAI_PIDS}" =~ ^[0-9]+$ ]]; then
  echo "faradai: invalid FARADAI_PIDS '${FARADAI_PIDS}' (expected a positive integer)" >&2
  exit 1
fi

USER="$(whoami)"

AIDER_CONF_MOUNT=()
if [ -f "${HOME}/.aider.conf.yml" ]; then
  AIDER_CONF_MOUNT=(-v "${HOME}/.aider.conf.yml:/home/${USER}/.aider.conf.yml:ro")
fi

# Word-split only — paths with spaces are not supported.
# Flag tokens (starting with -) are validated against an allowlist; value tokens pass through.
EXTRA_DOCKER_ARGS=()
if [[ -n "${FARADAI_DOCKER_ARGS:-}" ]]; then
  read -ra EXTRA_DOCKER_ARGS <<< "${FARADAI_DOCKER_ARGS}"
  _permitted=(--env -e --label -l --device --publish -p --hostname)
  for _arg in "${EXTRA_DOCKER_ARGS[@]}"; do
    [[ "${_arg}" != -* ]] && continue
    _ok=0
    for _flag in "${_permitted[@]}"; do
      if [[ "${_arg}" == "${_flag}" || "${_arg}" == "${_flag}="* ]]; then
        _ok=1; break
      fi
    done
    if (( _ok == 0 )); then
      echo "faradai: FARADAI_DOCKER_ARGS flag '${_arg}' is not in the allowlist" >&2
      echo "faradai: permitted: --env/-e, --label/-l, --device, --publish/-p, --hostname" >&2
      exit 1
    fi
  done
fi

if [[ "${FARADAI_DEBUG:-0}" == "1" ]]; then
  echo "faradai: WORKDIR=${FARADAI_WORKDIR} MEMORY=${FARADAI_MEMORY} CPUS=${FARADAI_CPUS} PIDS=${FARADAI_PIDS}" >&2
  set -x
fi

exec docker run -it --rm \
  --name faradai \
  --memory="${FARADAI_MEMORY}" \
  --cpus="${FARADAI_CPUS}" \
  --pids-limit="${FARADAI_PIDS}" \
  --cap-drop ALL \
  --security-opt no-new-privileges:true \
  -v "${HOME}/.claude:/home/${USER}/.claude" \
  -v "${HOME}/.claude/.credentials.json:/home/${USER}/.claude/.credentials.json:ro" \
  -v "${HOME}/.claude.json:/home/${USER}/.claude.json" \
  -v "${HOME}/.gitconfig:/home/${USER}/.gitconfig:ro" \
  -v "${HOME}/.ssh:/home/${USER}/.ssh:ro" \
  -v "${FARADAI_WORKDIR}:${FARADAI_WORKDIR}" \
  "${AIDER_CONF_MOUNT[@]}" \
  "${EXTRA_DOCKER_ARGS[@]}" \
  -w "${FARADAI_WORKDIR}" \
  faradai:latest \
  "$@"
