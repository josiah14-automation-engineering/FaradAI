#!/usr/bin/env bash
# Mock docker for unit tests. Handles only the calls faradai makes during
# pre-flight and container lifecycle; docker run exits 0 without doing anything.
case "$1" in
  info)    exit 0 ;;
  image)
    # docker image inspect faradai:latest --format '{{index .Config.Labels "..."}}'
    # If MOCK_IMAGE_USER is set, echo it so _check_image_user can read the label.
    [[ -n "${MOCK_IMAGE_USER:-}" ]] && echo "${MOCK_IMAGE_USER}"
    exit 0
    ;;
  inspect) exit 0 ;;  # exits 0 (container "exists") with no output (_CONTAINER_RUNNING="")
  rm)      exit 0 ;;
  run)     exit 0 ;;
  logs)    exit 0 ;;
  *)       exit 0 ;;
esac
